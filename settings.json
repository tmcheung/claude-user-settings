{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLOUD_ML_REGION": "europe-west1",
    "ANTHROPIC_VERTEX_PROJECT_ID": "smp-mb-engineering-dev",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "DISABLE_PROMPT_CACHING": "1",
    "VERTEX_REGION_CLAUDE_4_0_OPUS": "us-east5",
    "VERTEX_REGION_CLAUDE_4_1_OPUS": "us-east5",
    "VERTEX_REGION_CLAUDE_4_6_OPUS": "us-east5",
    "VERTEX_REGION_CLAUDE_4_6_SONNET": "europe-west1"
  },
  "permissions": {
    "allow": [
      "Edit",
      "MultiEdit",
      "WebFetch",
      "Write",
      "Bash(acli --help)",
      "Bash(acli jira --help)",
      "Bash(acli jira workitem --help)",
      "Bash(acli jira workitem view:*)",
      "Bash(acli jira issue view:*)",
      "Bash(xargs cat:*)",
      "Bash(./gradlew:*)",
      "Bash(find:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(./gradlew :*)",
      "Bash(sbt:*)",
      "Bash(mcp:*)",
      "Bash(pnpm:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(./gradlew :consumer:test:*)",
      "Bash(git rev-parse:*)",
      "Bash(./gradlew :api-server:compileKotlin:*)",
      "Bash(./gradlew :api-server:test:*)",
      "Bash(./gradlew test:*)",
      "Bash(acli issue:*)",
      "Bash(acli issue view:*)",
      "Bash(chmod:*)"
    ],
    "deny": []
  },
  "model": "claude-opus-4-6",
  "planMode": {
    "model": "claude-opus-4-6"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -group 'CLAUDE_CODE' -message '❗️Claude Code Needs Attention' -subtitle \"\" -sound Glass"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "terminal-notifier -group 'CLAUDE_CODE' -message '🏁Claude Code Stopped' -subtitle \"\" -sound Glass"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "aurora-k8s-inspector@vend-plugins": true,
    "code-search@vend-plugins": true,
    "developer-documentation@vend-plugins": true,
    "google-workspace@vend-plugins": true,
    "jira@vend-plugins": true,
    "meta@vend-plugins": true,
    "observability@vend-plugins": true,
    "safety-hooks@vend-plugins": true,
    "unleash@vend-plugins": true,
    "workplace@vend-plugins": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754290353394
  }
}
